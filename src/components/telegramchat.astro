---
interface Props {
  chatId: string;
  serverUrl: string;
}
const { chatId, serverUrl } = Astro.props;
---

<!-- DEBUG: remove after testing -->
<div id="telegram-chat-debug" style="position:fixed;bottom:0;left:0;background:red;color:white;padding:4px 8px;font-size:11px;z-index:99999;">
  chatId={chatId} server={serverUrl}
</div>

<script is:inline define:vars={{ chatId, serverUrl }}>
  console.log('[TelegramChat] chatId:', chatId, 'serverUrl:', serverUrl);
  if (chatId && serverUrl) {
    window.intergramId = chatId;
    window.intergramServer = serverUrl;
    window.intergramCustomizations = {
      titleClosed: 'Chat with us',
      titleOpen: 'Holo Support',
      introMessage: 'Hey! How can we help?',
      autoNoResponse: 'Our team is currently away — leave your email and we\'ll get back to you.',
      mainColor: '#34d399',
      alwaysUseFloatingButton: false
    };
    var s = document.createElement('script');
    s.id = 'intergram';
    s.src = serverUrl + '/js/widget.js';
    s.async = true;
    document.body.appendChild(s);
  }
</script>