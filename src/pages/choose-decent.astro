<script is:inline>
  /* ── PostHog analytics ─────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('a.cta-primary').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('marketplace_cta_clicked', { label: el.textContent.trim(), page: 'choose-decent' });
      });
    });
    document.querySelectorAll('a.cta-secondary').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('manifesto_cta_clicked', { page: 'choose-decent' });
      });
    });
    document.querySelectorAll('.decent-card a').forEach(function (el) {
      el.addEventListener('click', function () {
        var card = el.closest('.decent-card');
        var category = card ? card.querySelector('.font-mono-display')?.textContent?.trim() : 'unknown';
        window.posthog?.capture('product_category_explored', { category, page: 'choose-decent' });
      });
    });
    var waitlistEl = document.getElementById('waitlist-form');
    if (waitlistEl && typeof IntersectionObserver !== 'undefined') {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            window.posthog?.capture('waitlist_form_viewed', { page: window.location.pathname });
            obs.disconnect();
          }
        });
      }, { threshold: 0.5 });
      obs.observe(waitlistEl);
    }
  });

  /* ── Alternative Perspective: IntersectionObserver entry ────── */
  (function () {
    var win = document.getElementById('persp-win');
    if (!win) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          win.classList.add('is-visible');
          observer.disconnect();
        }
      });
    }, { threshold: 0.35 });

    observer.observe(win);
  })();
</script>
