---
import Base from '../layouts/Base.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
---

<Base title="Choose Decent | Interflow Marketplace">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Instrument+Serif:ital@0;1&display=swap');

    :root {
      --decent-blue: #1d6ce0;
      --decent-teal: #0da5a0;
      --decent-amber: #e0b400;
      --decent-blue-light: rgba(29, 108, 224, 0.06);
      --decent-teal-light: rgba(13, 165, 160, 0.06);
    }

    .font-mono-display { font-family: 'Space Mono', 'Courier New', monospace; }
    .font-serif-display { font-family: 'Instrument Serif', Georgia, serif; }

    /* Stagger reveal animations */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes pulse-ring {
      0% { transform: scale(1); opacity: 0.5; }
      100% { transform: scale(1.8); opacity: 0; }
    }

    .anim-fade-up {
      opacity: 0;
      animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .anim-fade-in {
      opacity: 0;
      animation: fadeIn 1s ease forwards;
    }

    .delay-1 { animation-delay: 0.15s; }
    .delay-2 { animation-delay: 0.3s; }
    .delay-3 { animation-delay: 0.5s; }
    .delay-4 { animation-delay: 0.7s; }
    .delay-5 { animation-delay: 0.9s; }
    .delay-6 { animation-delay: 1.1s; }
    .delay-7 { animation-delay: 1.4s; }

    /* Rotating words */
    .word-rotator {
      display: inline-block;
      height: 1.15em;
      overflow: hidden;
      vertical-align: bottom;
      position: relative;
      min-width: 220px;
    }
    .word-rotator span {
      display: block;
      animation: wordCycle 12s cubic-bezier(0.4, 0, 0.2, 1) infinite;
      line-height: 1.15;
    }
    @keyframes wordCycle {
      0%, 14%   { transform: translateY(0%); }
      16.66%, 30.66% { transform: translateY(-100%); }
      33.33%, 47.33% { transform: translateY(-200%); }
      50%, 64%  { transform: translateY(-300%); }
      66.66%, 80.66% { transform: translateY(-400%); }
      83.33%, 97.33% { transform: translateY(-500%); }
      100%      { transform: translateY(-600%); }
    }

    /* Hover on cards */
    .decent-card {
      position: relative;
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease;
    }
    .decent-card:hover {
      transform: translateY(-3px);
      border-color: #d0d0d0;
    }

    /* Divider */
    .slash-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      color: #bbb;
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }
    .slash-divider::before,
    .slash-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, #e5e5e5 50%, transparent);
    }

    /* Stat counter */
    .stat-block { text-align: center; }
    .stat-block .num {
      font-family: 'Space Mono', monospace;
      font-size: 2.5rem;
      font-weight: 700;
      color: #111;
      line-height: 1;
    }
    .stat-block .label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #999;
      margin-top: 4px;
    }

    /* Live dot */
    .live-dot {
      width: 8px; height: 8px;
      background: var(--decent-teal);
      border-radius: 50%;
      position: relative;
      display: inline-block;
    }
    .live-dot::after {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      border: 1.5px solid var(--decent-teal);
      animation: pulse-ring 2s ease-out infinite;
    }

    /* CTA button */
    .cta-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 32px;
      background: #111;
      color: #fff;
      font-family: 'Inter', system-ui, sans-serif;
      font-weight: 600;
      font-size: 0.875rem;
      letter-spacing: 0.01em;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s ease;
      text-decoration: none;
    }
    .cta-primary:hover {
      background: #333;
      transform: translateY(-1px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    }
    .cta-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 32px;
      background: transparent;
      color: #555;
      font-family: 'Inter', system-ui, sans-serif;
      font-weight: 600;
      font-size: 0.875rem;
      letter-spacing: 0.01em;
      border: 1.5px solid #ddd;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s ease;
      text-decoration: none;
    }
    .cta-secondary:hover {
      border-color: #bbb;
      background: #fafafa;
    }

    /* Scrolling marquee */
    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .marquee-track {
      display: flex;
      width: max-content;
      animation: marquee 40s linear infinite;
    }
    .marquee-track:hover { animation-play-state: paused; }
  </style>

  <!-- ===== HEADER ===== -->
  <header class="fixed top-0 left-0 right-0 z-50 border-b border-gray-100 bg-white/85 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 h-14 flex items-center justify-between">
      <a href={base} class="flex items-center gap-2.5 group">
        <img src={`${base}holo-mark.svg`} alt="Holo" class="w-7 h-7 grayscale opacity-60" />
        <span class="text-gray-900 font-semibold text-lg tracking-tight font-sans">Marketplace</span>
      </a>
      <nav class="flex items-center gap-5 text-sm">
        <a href={base} class="text-gray-900 font-medium text-sm">Choose Decent</a>
        <a href={`${base}products`} class="text-gray-400 hover:text-gray-700 transition-colors">Products</a>
      </nav>
    </div>
  </header>

  <main class="pt-14">

    <!-- ===== HERO ===== -->
    <section class="relative min-h-[92vh] flex items-center overflow-hidden">
      <div class="relative max-w-5xl mx-auto px-5 sm:px-8 py-24 sm:py-32">
        <!-- Eyebrow -->
        <div class="anim-fade-up delay-1 flex items-center gap-3 mb-8">
          <span class="live-dot"></span>
          <span class="font-mono-display text-xs uppercase tracking-[0.2em] text-gray-400">Building since 2004 &mdash; Not vaporware</span>
        </div>

        <!-- Main headline -->
        <h1 class="anim-fade-up delay-2 mb-6">
          <span class="block font-serif-display text-5xl sm:text-7xl md:text-8xl text-gray-900 leading-[0.95] tracking-tight">
            Choose
          </span>
          <span class="block font-serif-display italic text-5xl sm:text-7xl md:text-8xl leading-[0.95] tracking-tight" style="color: var(--decent-blue);">
            Decent<span class="font-mono-display not-italic text-3xl sm:text-5xl md:text-6xl text-gray-300 ml-1"> _</span>
          </span>
        </h1>

        <!-- Rotating words -->
        <div class="anim-fade-up delay-3 font-mono-display text-lg sm:text-xl text-gray-400 mb-10 flex items-baseline gap-2 flex-wrap">
          <span class="text-gray-300">$</span>
          <span>Decent</span>
          <span class="word-rotator" style="color: var(--decent-teal);">
            <span>Deployment</span>
            <span>Hosting</span>
            <span>AI</span>
            <span>Finance</span>
            <span>Compute</span>
            <span>Infrastructure</span>
            <span>Deployment</span>
          </span>
        </div>

        <!-- Manifesto blurb -->
        <p class="anim-fade-up delay-4 max-w-xl text-gray-500 text-base sm:text-lg leading-relaxed mb-12" style="font-family: 'Inter', sans-serif;">
          Crypto lost its soul. AI got swallowed by a handful of corporations. 
          Compute — the thing that actually matters — is being centralized by default.
          <span class="text-gray-800 font-medium"> We've been building the alternative since before the problem was cool.</span>
        </p>

        <!-- CTAs -->
        <div class="anim-fade-up delay-5 flex flex-wrap gap-4">
          <a href={`${base}products`} class="cta-primary">
            Browse the Marketplace
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9.5 4.5M13 8l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#manifesto" class="cta-secondary">
            Read the Manifesto
          </a>
        </div>
      </div>
    </section>

    <!-- ===== MARQUEE STRIP ===== -->
    <div class="border-y border-gray-100 bg-gray-50/60 py-3 overflow-hidden">
      <div class="marquee-track">
        {[...Array(2)].map(() => (
          <div class="flex items-center gap-8 px-4 shrink-0">
            <span class="font-mono-display text-[11px] uppercase tracking-[0.15em] text-gray-400">Decent Deployment</span>
            <span class="text-gray-200">/</span>
            <span class="font-mono-display text-[11px] uppercase tracking-[0.15em] text-gray-400">Decent Hosting</span>
            <span class="text-gray-200">/</span>
            <span class="font-mono-display text-[11px] uppercase tracking-[0.15em] text-gray-400">Decent AI</span>
            <span class="text-gray-200">/</span>
            <span class="font-mono-display text-[11px] uppercase tracking-[0.15em] text-gray-400">Decent Finance</span>
            <span class="text-gray-200">/</span>
            <span class="font-mono-display text-[11px] uppercase tracking-[0.15em] text-gray-400">Decent Compute</span>
            <span class="text-gray-200">/</span>
            <span class="font-mono-display text-[11px] uppercase tracking-[0.15em] text-gray-400">Decent Infrastructure</span>
            <span class="text-gray-200 pr-4">/</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ===== ACT 1: NAME THE PROBLEM ===== -->
    <section id="manifesto" class="py-24 sm:py-32 relative">
      <div class="max-w-4xl mx-auto px-5 sm:px-8">
        <div class="slash-divider mb-16">Act I &mdash; The Problem</div>

        <h2 class="font-serif-display text-3xl sm:text-5xl text-gray-900 leading-tight mb-8">
          It's an <span class="italic" style="color: var(--decent-amber);">indecent</span> world.
        </h2>
        <div class="space-y-6 text-gray-500 text-base sm:text-lg leading-relaxed max-w-2xl" style="font-family: 'Inter', sans-serif;">
          <p>
            Your deployment pipeline runs through someone else's servers. 
            Your data feeds someone else's model. 
            Everything about modern tech is designed to <span class="text-gray-800">extract from you</span>.
          </p>
          <p>
            Crypto promised decentralization, then became part of the very system it was supposed to replace.
            The rebels got rich and stopped rebelling. The vibe merchants ran out of vibe.
          </p>
          <p>
            Meanwhile, compute — the actual scarce resource powering the AI economy — 
            is being swallowed whole by a handful of corporations building infrastructure 
            that serves shareholders, not humans.
          </p>
          <p class="font-mono-display text-sm tracking-wide" style="color: var(--decent-teal); opacity: 0.7;">
            No one's offering an alternative. No one credible, anyway.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== ACT 2: THE ALTERNATIVE ===== -->
    <section class="py-24 sm:py-32 relative border-t border-gray-100">
      <div class="max-w-4xl mx-auto px-5 sm:px-8">
        <div class="slash-divider mb-16">Act II &mdash; The Alternative</div>

        <h2 class="font-serif-display text-3xl sm:text-5xl text-gray-900 leading-tight mb-8">
          We've been building something <span class="italic" style="color: var(--decent-blue);">decent.</span>
        </h2>
        <div class="space-y-6 text-gray-500 text-base sm:text-lg leading-relaxed max-w-2xl mb-16" style="font-family: 'Inter', sans-serif;">
          <p>
            Not perfect. Not excellent-for-the-few.
            <span class="text-gray-800 font-medium"> Decent — for the many.</span>
          </p>
          <p>
            Sovereign compute. Verifiable deployment. Crypto-native economics without the casino. 
            Peer-to-peer infrastructure built from first principles by people who understood the problem 
            before the problem was fashionable.
          </p>
          <p>
            Holochain wasn't a reaction to blockchain hype — it was an alternative architecture, 
            in development since 2004, designed so that no centralized player can extract your data, 
            your sovereignty, or your wallet.
          </p>
        </div>

        <!-- What "Decent" means -->
        <div class="grid sm:grid-cols-3 gap-4 mb-16">
          <div class="decent-card rounded-lg border border-gray-100 bg-gray-50/50 p-6">
            <div class="font-mono-display text-[11px] uppercase tracking-[0.2em] text-gray-400 mb-3">De-cent-ralized</div>
            <p class="text-gray-600 text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
              It's literally what we build. Agent-centric, distributed computing where you own your infrastructure.
            </p>
          </div>
          <div class="decent-card rounded-lg border border-gray-100 bg-gray-50/50 p-6">
            <div class="font-mono-display text-[11px] uppercase tracking-[0.2em] text-gray-400 mb-3">Good Enough</div>
            <p class="text-gray-600 text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Doing something decent for the many is better than doing something excellent for the few.
            </p>
          </div>
          <div class="decent-card rounded-lg border border-gray-100 bg-gray-50/50 p-6">
            <div class="font-mono-display text-[11px] uppercase tracking-[0.2em] text-gray-400 mb-3">Moral Standards</div>
            <p class="text-gray-600 text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Having basic decency in an indecent world. Tech that serves humans, not the other way around.
            </p>
          </div>
        </div>

        <!-- Stats / credibility -->
        <div class="flex flex-wrap justify-center gap-12 sm:gap-20 py-10 border-t border-b border-gray-100">
          <div class="stat-block">
            <div class="num">20+</div>
            <div class="label">Years Building</div>
          </div>
          <div class="stat-block">
            <div class="num" style="color: var(--decent-teal);">Live</div>
            <div class="label">Not Vaporware</div>
          </div>
          <div class="stat-block">
            <div class="num">0</div>
            <div class="label">Transaction Fees</div>
          </div>
          <div class="stat-block">
            <div class="num">MIT</div>
            <div class="label">Licensed</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PRODUCT TEASERS ===== -->
    <section class="py-24 sm:py-32 relative border-t border-gray-100">
      <div class="max-w-5xl mx-auto px-5 sm:px-8">
        <div class="slash-divider mb-16">What We Ship</div>

        <div class="grid sm:grid-cols-2 gap-5">
          <!-- Decent Deployment -->
          <div class="decent-card rounded-lg border border-gray-100 bg-white p-7 sm:p-8">
            <div class="font-mono-display text-xs uppercase tracking-[0.15em] mb-4" style="color: var(--decent-teal);">Decent Deployment</div>
            <h3 class="font-serif-display text-2xl text-gray-900 mb-3">Finally, a decent deploy.</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-6" style="font-family: 'Inter', sans-serif;">
              Your dev team deserves deployment that isn't Amazon or Google. 
              Sovereign, verifiable, and built for developers using AI assistance to ship faster.
            </p>
            <a href={`${base}products`} class="font-mono-display text-xs uppercase tracking-wider text-gray-400 hover:text-gray-700 transition-colors">
              Explore &rarr;
            </a>
          </div>

          <!-- Decent Hosting -->
          <div class="decent-card rounded-lg border border-gray-100 bg-white p-7 sm:p-8">
            <div class="font-mono-display text-xs uppercase tracking-[0.15em] mb-4" style="color: var(--decent-teal);">Decent Hosting</div>
            <h3 class="font-serif-display text-2xl text-gray-900 mb-3">Edge hosting, your terms.</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-6" style="font-family: 'Inter', sans-serif;">
              Run a HoloPort. Host Holochain apps at the edge. 
              Distributed infrastructure where you earn by participating — not by renting from a landlord.
            </p>
            <a href={`${base}products`} class="font-mono-display text-xs uppercase tracking-wider text-gray-400 hover:text-gray-700 transition-colors">
              Explore &rarr;
            </a>
          </div>

          <!-- Decent AI -->
          <div class="decent-card rounded-lg border border-gray-100 bg-white p-7 sm:p-8">
            <div class="font-mono-display text-xs uppercase tracking-[0.15em] mb-4" style="color: var(--decent-teal);">Decent AI</div>
            <h3 class="font-serif-display text-2xl text-gray-900 mb-3">AI that works for you.</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-6" style="font-family: 'Inter', sans-serif;">
              Decentralized compute for the AI economy. 
              Infrastructure that doesn't require surrendering your data or sovereignty.
            </p>
            <a href={`${base}products`} class="font-mono-display text-xs uppercase tracking-wider text-gray-400 hover:text-gray-700 transition-colors">
              Explore &rarr;
            </a>
          </div>

          <!-- Decent Finance -->
          <div class="decent-card rounded-lg border border-gray-100 bg-white p-7 sm:p-8">
            <div class="font-mono-display text-xs uppercase tracking-[0.15em] mb-4" style="color: var(--decent-teal);">Decent Finance</div>
            <h3 class="font-serif-display text-2xl text-gray-900 mb-3">Post-blockchain DeFi.</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-6" style="font-family: 'Inter', sans-serif;">
              Accounting is local. Logic is interpreted. Clearing is decentralized.
              Crypto-native economics without the casino.
            </p>
            <a href={`${base}products`} class="font-mono-display text-xs uppercase tracking-wider text-gray-400 hover:text-gray-700 transition-colors">
              Explore &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== ACT 3: INVITATION ===== -->
    <section class="py-24 sm:py-32 relative border-t border-gray-100">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 text-center">
        <div class="slash-divider mb-16">Act III &mdash; Your Move</div>

        <h2 class="font-serif-display text-4xl sm:text-6xl text-gray-900 leading-tight mb-6">
          Choose <span class="italic" style="color: var(--decent-blue);">decent.</span>
        </h2>
        <p class="text-gray-500 text-base sm:text-lg leading-relaxed max-w-lg mx-auto mb-4" style="font-family: 'Inter', sans-serif;">
          Join the Interflow Network. Deploy your first app. Use the marketplace.
          Not as a speculative bet — as entry into an ecosystem where your participation actually means something.
        </p>
       <p class="font-serif-display italic text-lg sm:text-xl text-gray-400 mb-8 max-w-md mx-auto">
          &ldquo;Doing something decent for the many is maybe better than doing something excellent for the few.&rdquo;
        </p>

        <!-- Waitlist signup -->
        <div class="mb-12">
          <WaitlistForm />
        </div

        <div class="flex flex-wrap justify-center gap-4">
          <a href={`${base}products`} class="cta-primary">
            Enter the Marketplace
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9.5 4.5M13 8l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="border-t border-gray-100 py-10">
      <div class="max-w-7xl mx-auto px-5 sm:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2.5">
          <img src={`${base}holo-mark.svg`} alt="Holo" class="w-5 h-5 grayscale opacity-40" />
          <span class="font-mono-display text-[11px] uppercase tracking-[0.15em] text-gray-400">Interflow Marketplace</span>
        </div>
        <nav class="flex items-center gap-6">
          <a href={`${base}products`} class="text-xs text-gray-400 hover:text-gray-700 transition-colors">Products</a>
          <a href={base} class="text-xs text-gray-400 hover:text-gray-700 transition-colors">Choose Decent</a>
        </nav>
        <span class="font-mono-display text-[10px] text-gray-300">Built on Holochain &mdash; MIT Licensed</span>
      </div>
    </footer>

  </main>
</Base>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('a.cta-primary').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('marketplace_cta_clicked', {
          label: el.textContent.trim(),
          page: 'home',
        });
      });
    });

    document.querySelectorAll('a.cta-secondary').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('manifesto_cta_clicked', { page: 'home' });
      });
    });

    var waitlistEl = document.getElementById('waitlist-form');
    if (waitlistEl && typeof IntersectionObserver !== 'undefined') {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            if (window.posthog && typeof window.posthog.capture === 'function') {
              window.posthog.capture('waitlist_form_viewed', { page: window.location.pathname });
            }
            obs.disconnect();
          }
        });
      }, { threshold: 0.5 });
      obs.observe(waitlistEl);
    }

    document.querySelectorAll('.decent-card a').forEach(function (el) {
      el.addEventListener('click', function () {
        var card = el.closest('.decent-card');
        var category = card ? card.querySelector('[class*="mono-display"]')?.textContent?.trim() : null;
        window.posthog?.capture('product_category_explored', {
          category: category,
          page: 'home',
        });
      });
    });
  });
</script>
