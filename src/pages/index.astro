<script is:inline>
  /* ── PostHog analytics ───────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('a.cta-primary').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('marketplace_cta_clicked', {
          label: el.textContent.trim(),
          page: 'home',
        });
      });
    });
    document.querySelectorAll('a.cta-secondary').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('manifesto_cta_clicked', { page: 'home' });
      });
    });
    document.querySelectorAll('.decent-card a').forEach(function (el) {
      el.addEventListener('click', function () {
        var card = el.closest('.decent-card');
        var category = card ? card.querySelector('.font-mono-display')?.textContent?.trim() : 'unknown';
        window.posthog?.capture('product_category_explored', { category, page: 'home' });
      });
    });
  });

  /* ── Window Pane Slider ──────────────────────────────────────── */
  (function () {
    var track = document.getElementById('wps-track');
    var dotsEl = document.getElementById('wps-dots');
    var prev = document.getElementById('wps-prev');
    var next = document.getElementById('wps-next');
    if (!track || !prev || !next) return;

    var total = 4;
    var current = 0;

    function goTo(i) {
      current = (i + total) % total;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dotsEl.querySelectorAll('.slider-dot').forEach(function (d, idx) {
        d.classList.toggle('active', idx === current);
      });
    }

    prev.addEventListener('click', function () { goTo(current - 1); });
    next.addEventListener('click', function () { goTo(current + 1); });

    dotsEl.querySelectorAll('.slider-dot').forEach(function (d) {
      d.addEventListener('click', function () {
        goTo(parseInt(d.dataset.index));
      });
    });

    /* Keyboard */
    document.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft')  goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });

    /* Touch swipe */
    var startX = 0;
    track.addEventListener('touchstart', function (e) { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    });

    /* Auto-advance */
    setInterval(function () { goTo(current + 1); }, 5000);
  })();
</script>
