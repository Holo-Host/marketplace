---
export const prerender = false;

import { getCollection } from 'astro:content';
import { env } from 'cloudflare:workers';
import Base from '../layouts/Base.astro';
import ProductCatalog from '../components/ProductCatalog';
import AccessGate from '../components/AccessGate.astro';
import '../styles/global.css';
import TelegramChat from '../components/TelegramChat.astro';

// Access Cloudflare Worker secrets via the cloudflare:workers module (Astro v6)
const COOKIE_SECRET = env.COOKIE_SECRET || '';
const INTERGRAM_ID = env.INTERGRAM_ID || '';
const INTERGRAM_SERVER = env.INTERGRAM_SERVER || '';
console.log('[DEBUG] INTERGRAM_ID:', INTERGRAM_ID);
console.log('[DEBUG] INTERGRAM_SERVER:', INTERGRAM_SERVER);

async function verifyAccessToken(token: string): Promise<boolean> {
  if (!COOKIE_SECRET || !token) return false;
  const dotIndex = token.indexOf('.');
  if (dotIndex === -1) return false;

  const timestamp = token.substring(0, dotIndex);
  const signature = token.substring(dotIndex + 1);

  const encoder = new TextEncoder();
  const key = await crypto.subtle.importKey(
    'raw',
    encoder.encode(COOKIE_SECRET),
    { name: 'HMAC', hash: 'SHA-256' },
    false,
    ['sign']
  );
  const sig = await crypto.subtle.sign('HMAC', key, encoder.encode(timestamp));
  const expectedSig = Array.from(new Uint8Array(sig))
    .map(b => b.toString(16).padStart(2, '0'))
    .join('');

  return expectedSig === signature;
}

// Parse cookies from the request
const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookies = Object.fromEntries(
  cookieHeader.split(';').map(c => {
    const [key, ...rest] = c.trim().split('=');
    return [key, rest.join('=')];
  })
);

const accessToken = cookies['access_token'] || '';
const hasAccess = await verifyAccessToken(accessToken);

// Load product data only if authorized
let products: any[] = [];
let providers: any[] = [];

if (hasAccess) {
  const productEntries = await getCollection('products');
  const providerEntries = await getCollection('providers');

  products = productEntries
    .map((entry) => ({
      id: entry.id,
      name: entry.data.name,
      provider: entry.data.provider,
      description: entry.data.description,
      longDescription: entry.data.longDescription,
      tags: entry.data.tags,
      category: entry.data.category,
      status: entry.data.status,
      pricing: entry.data.pricing,
      action: entry.data.action,
      featured: entry.data.featured,
      specs: entry.data.specs,
      sortOrder: entry.data.sortOrder,
      source: 'static' as const,
    }))
    .sort((a, b) => a.sortOrder - b.sortOrder);

  providers = providerEntries
    .map((entry) => ({
      id: entry.id,
      name: entry.data.name,
      color: entry.data.color,
      description: entry.data.description,
      logo: entry.data.logo,
      website: entry.data.website,
      contact: entry.data.contact,
      sortOrder: entry.data.sortOrder,
    }))
    .sort((a, b) => a.sortOrder - b.sortOrder);
}

const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');
---

<Base
  title="Products | Holo Marketplace"
  description="Browse decentralized hosting, developer tools, community currencies, AI infrastructure, and VPS hosting from Holo, Holochain, Unyt, Coasys, and Mycelium."
>
  {hasAccess ? (
    <ProductCatalog client:load products={products} providers={providers} />
  ) : (
    <AccessGate error={error} />
  )}
  <script is:inline define:vars={{ chatId: INTERGRAM_ID, serverUrl: INTERGRAM_SERVER }}>
    if (chatId && serverUrl) {
      window.intergramId = chatId;
      window.intergramServer = serverUrl;
      window.intergramCustomizations = {
        titleClosed: 'Chat with us',
        titleOpen: 'Holo Support',
        introMessage: 'Hey! How can we help?',
        autoNoResponse: 'Our team is currently away — leave your email and we\'ll get back to you.',
        mainColor: '#34d399',
        alwaysUseFloatingButton: false
      };
      var s = document.createElement('script');
      s.id = 'intergram';
      s.src = serverUrl + '/js/widget.js';
      s.async = true;
      document.body.appendChild(s);
    }
  </script>
</Base>
