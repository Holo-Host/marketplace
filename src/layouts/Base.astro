---
interface Props {
  title?: string;
}

const { title = 'Marketplace' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Decentralized hosting, tools, currencies, and infrastructure from the Holo ecosystem and partners." />
    <link rel="icon" type="image/svg+xml" href="/marketplace/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-[#0a0a0f] text-gray-100 antialiased">
    <slot />
  </body>
</html>
